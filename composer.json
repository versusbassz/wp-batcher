{
	"name": "versusbassz/wp-batcher",
	"description": "Iterate over thousands of posts/users/etc. in WordPress without getting OOM and writing boilerplate code",
	"type": "library",
	"keywords": [
		"wordpress",
		"iterator"
	],
	"homepage": "https://github.com/versusbassz/wp-batcher",
	"authors": [
		{
			"name": "Vladimir Sklyar",
			"email": "versus.post@gmail.com",
			"homepage": "https://versusbassz.com/"
		}
	],
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.2"
	},
	"autoload": {
		"psr-4": {
			"Versusbassz\\WpBatcher\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Versusbassz\\WpBatcher\\Tests\\": "tests/src/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9",
		"symfony/var-dumper": "^7.4",
		"yoast/phpunit-polyfills": "^1.1.5"
	},
	"config": {
		"platform": {
			"php": "8.2.31"
		}
	}
}
